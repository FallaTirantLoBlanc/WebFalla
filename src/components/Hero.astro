---
// CUSTOMIZE: Replace hero image and logo in src/assets/
import heroImage from "../assets/foto-fondo.jpg";
import logo from "../assets/logo-fondo.png";
import { siteConfig } from "../data/siteConfig";
import { heroData } from "../data/content";
---

<section
  class="relative min-h-[85vh] min-h-[85svh] flex items-center justify-center overflow-hidden bg-secondary px-4"
>
  <div class="absolute inset-0 z-0">
    <img
      src={heroImage.src}
      alt="Hero background"
      class="w-full h-full object-cover opacity-50 brightness-75 transition-transform duration-1000 hover:scale-105"
      loading="eager"
    />
    <div
      class="absolute inset-0 bg-gradient-to-b from-secondary/60 via-secondary/30 to-base-100"
    >
    </div>
    <div
      class="absolute inset-0 bg-gradient-to-r from-secondary/50 via-transparent to-secondary/50"
    >
    </div>
  </div>

  <div class="relative z-10 text-center px-4 sm:px-6 max-w-5xl w-full">
    <!-- CUSTOMIZE: Replace logo in src/assets/ -->
    <div class="mb-8 flex justify-center">
      <img
        src={logo.src}
        alt={`${siteConfig.siteName} Logo`}
        class="w-24 h-24 md:w-32 md:h-32 drop-shadow-2xl animate-[fadeIn_1s_ease-out]"
      />
    </div>

    <div
      class="inline-block px-6 py-2 mb-6 border border-accent/40 backdrop-blur-sm bg-secondary/30"
    >
      <span
        class="text-[10px] md:text-xs uppercase font-bold tracking-[0.4em] text-accent"
        >{siteConfig.siteMotto}</span
      >
    </div>

    <h1
      class="text-4xl sm:text-5xl md:text-8xl lg:text-9xl mb-4 text-white leading-[0.9] tracking-tighter drop-shadow-lg"
    >
      {heroData.heading}
    </h1>
    <h2
      data-i18n="hero.subtitle"
      class="text-xl sm:text-2xl md:text-4xl text-accent mb-6 tracking-wide"
    >
      {heroData.subtitle}
    </h2>
    <div class="w-24 h-[2px] bg-accent mx-auto mb-8"></div>
    <p
      data-i18n="hero.desc"
      class="text-base md:text-lg text-white/80 mb-12 font-normal max-w-2xl mx-auto leading-relaxed"
    >
      {heroData.description}
    </p>
  </div>

  <div
    class="absolute bottom-6 sm:bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40"
  >
    <div class="w-px h-8 sm:h-12 bg-accent animate-pulse"></div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
