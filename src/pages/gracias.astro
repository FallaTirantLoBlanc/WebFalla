---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Gracias" description="Tu inscripción ha sido recibida correctamente.">
  <Navbar />

  <main>
    <section class="camo-bg">
      <div class="text-center max-w-4xl mx-auto py-28 px-4 sm:px-6">
        <div class="reveal">
          <span
            data-i18n="gracias.label"
            class="text-accent text-[10px] font-bold uppercase tracking-[0.5em] mb-4 block"
            >Gracias</span
          >
        </div>
        <div class="reveal delay-100">
          <h1
            data-i18n-html="gracias.title"
            class="text-5xl sm:text-6xl md:text-7xl leading-tight mb-6"
          >
            Gracias por tu inscripción
          </h1>
        </div>
        <div class="reveal delay-200">
          <p
            data-i18n="gracias.subtitle"
            class="max-w-2xl mx-auto opacity-70 text-sm sm:text-base mb-8"
          >
            Tu información ha sido recibida correctamente.
          </p>
          <p data-i18n="gracias.description" class="max-w-2xl mx-auto opacity-60 text-sm sm:text-base mb-10">
            Pronto nos pondremos en contacto contigo para seguir con el proceso.
          </p>
          <a href="/" class="btn-tactical py-4 px-12" data-i18n="gracias.return">
            Volver a la página principal
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
