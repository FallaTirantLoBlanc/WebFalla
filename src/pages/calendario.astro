---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Calendario" description="Calendario de eventos — Falla Tirant lo Blanc">
  <Navbar />

  <main>
    <section class="camo-bg">
      <div class="text-center max-w-4xl mx-auto py-24 px-4 sm:px-6">
        <div class="reveal">
          <span data-i18n="calendario.label" class="text-accent text-[10px] font-bold uppercase tracking-[0.5em] mb-4 block">Calendario</span>
        </div>
        <div class="reveal delay-100">
          <h1 data-i18n="calendario.title" class="text-5xl sm:text-6xl md:text-7xl leading-tight mb-6">Eventos y actividades</h1>
        </div>
        <div class="reveal delay-200">
          <p data-i18n="calendario.subtitle" class="max-w-2xl mx-auto opacity-70 text-sm sm:text-base">Consulta nuestro calendario de actividades.</p>
        </div>
      </div>
    </section>

    <section class="bg-base-200 py-20 sm:py-28">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <div class="reveal mb-10">
          <div class="w-full max-w-full overflow-hidden rounded-3xl border border-base-300 bg-base-100 p-6 shadow-xl shadow-black/5">
            <h2 data-i18n="calendario.panel.title" class="text-3xl mb-4">Calendario eventos - Falla Tirant lo Blanc</h2>
            <p data-i18n="calendario.panel.description" class="max-w-2xl opacity-70 text-sm mb-6">Aquí tienes el calendario público de la comisión.</p>

            <div class="w-full overflow-hidden rounded-2xl">
              <iframe
                src="https://calendar.google.com/calendar/embed?src=06e175c8300c3d846c72d9d181efb953b4e5a7e7a2e13f9200fe32148548f01d%40group.calendar.google.com&ctz=Europe%2FMadrid&mode=MONTH"
                style="border:0; width:100%; min-height:620px;"
                width="100%"
                height="700"
                frameborder="0"
                scrolling="no"
                title="Calendario Falla Tirant lo Blanc"
                class="w-full rounded-2xl"
              ></iframe>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
